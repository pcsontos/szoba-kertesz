# Copy this file to .env and fill in real values. Never commit .env.

# Anthropic API (used by the CLI agent)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL=claude-sonnet-4-6

# Postgres connection strings (see docker-compose.yml, init.sql)
DATABASE_URL=postgresql://REPLACE_ADMIN_USER:REPLACE_ADMIN_PASSWORD@localhost:5433/szoba-kertesz
DATABASE_URL_READONLY=postgresql://szoba-kertesz_ro:szoba-kertesz_ro@localhost:5433/szoba-kertesz

# Postgres container/admin credentials (used by docker-compose.yml)
POSTGRES_DB=szoba-kertesz
POSTGRES_ADMIN_USER=REPLACE_ADMIN_USER
POSTGRES_ADMIN_PASSWORD=REPLACE_ADMIN_PASSWORD
